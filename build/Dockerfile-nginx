# live-api/build/Dockerfile-nginx
FROM nginx:alpine

COPY live-api/build/nginx.conf /etc/nginx/conf.d/default.conf

RUN apk add --no-cache openssl \
    && mkdir -p /etc/nginx/ssl \
    && openssl req -x509 -newkey rsa:4096 -keyout /etc/nginx/ssl/server.key -out /etc/nginx/ssl/server.crt -days 365 -nodes -subj "/CN=mojproject-dev.com"

EXPOSE 80 443

CMD ["nginx", "-g", "daemon off;"]
